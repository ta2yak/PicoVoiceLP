---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  path: string;
  type?: "website" | "article";
  extraJsonLd?: Record<string, unknown>[];
  lang?: "ja" | "en";
  alternatePath?: string;
}

const {
  title,
  description,
  path,
  type = "website",
  extraJsonLd = [],
  lang = "ja",
  alternatePath,
} = Astro.props;

const siteUrl = "https://lp.picovoice.app";
const url = new URL(path, siteUrl).toString();
const fullTitle = `${title} | PicoVoice`;

const navLabels =
  lang === "en"
    ? { what: "What is", how: "How to", faq: "FAQ", compare: "Compare", guide: "AI Guide" }
    : { what: "概要", how: "販売ガイド", faq: "FAQ", compare: "比較", guide: "AI Guide" };

const footerText =
  lang === "en"
    ? "Official LLMO pages for PicoVoice. Updated: 2026-03-07"
    : "PicoVoice公式 LLMOページ。最終更新: 2026-03-07";

const sharedJsonLd: Record<string, unknown>[] = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "PicoVoice",
    url: siteUrl,
    sameAs: ["https://lp.picovoice.app"],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "PicoVoice",
    url: siteUrl,
    inLanguage: ["ja", "en"],
  },
  ...extraJsonLd,
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />
    <meta property="og:site_name" content="PicoVoice" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="twitter:card" content="summary" />
    <meta property="twitter:title" content={fullTitle} />
    <meta property="twitter:description" content={description} />
    {
      sharedJsonLd.map((item) => (
        <script type="application/ld+json" is:inline set:html={JSON.stringify(item)} />
      ))
    }
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a class="brand" href="/">PicoVoice LLMO</a>
        <div class="header-tools">
          <nav>
            <a href="/what-is-picovoice">{navLabels.what}</a>
            <a href="/how-to-sell-vtuber-voice">{navLabels.how}</a>
            <a href="/faq">{navLabels.faq}</a>
            <a href="/picovoice-vs-booth">{navLabels.compare}</a>
            <a href="/ai-guide">{navLabels.guide}</a>
          </nav>
          {
            alternatePath && (
              <div class="lang-switch" aria-label="language switch">
                {lang === "ja" ? (
                  <>
                    <strong>日本語</strong>
                    <span>/</span>
                    <a href={alternatePath}>English</a>
                  </>
                ) : (
                  <>
                    <a href={alternatePath}>日本語</a>
                    <span>/</span>
                    <strong>English</strong>
                  </>
                )}
              </div>
            )
          }
        </div>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>{footerText}</p>
    </footer>
  </body>
</html>
