---
interface Props {
  title: string;
  description: string;
  path: string;
}

const { title, description, path } = Astro.props;
const siteUrl = "https://lp.picovoice.app";
const url = new URL(path, siteUrl).toString();
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="canonical" href={url} />
    <style>
      *, *::before, *::after { box-sizing: border-box; }
      html, body {
        margin: 0; padding: 0;
        font-family: "Noto Sans JP", "Hiragino Kaku Gothic ProN", system-ui, sans-serif;
        color: #1a1a2e;
        background: #fff;
        line-height: 1.75;
        -webkit-font-smoothing: antialiased;
      }
      main {
        max-width: 800px;
        margin: 0 auto;
        padding: 40px 20px 80px;
      }
      h1, h2, h3 { line-height: 1.3; margin-top: 0; }
      h1 { font-size: 1.6rem; margin-bottom: 12px; }
      h2 { font-size: 1.3rem; margin-bottom: 10px; margin-top: 32px; }
      h3 { font-size: 1.1rem; margin-top: 20px; }
      p, li, td, th { font-size: 1rem; }
      a { color: #7a5af8; }
      ul, ol { padding-left: 20px; }
      table { width: 100%; border-collapse: collapse; margin-top: 12px; }
      th, td { border: 1px solid #e8e0ff; padding: 10px; text-align: left; vertical-align: top; }
      th { background: #f6f2ff; }
      hr { border: none; border-top: 1px solid #e8e0ff; margin: 40px 0; }
      section { margin-bottom: 24px; }
    </style>
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
