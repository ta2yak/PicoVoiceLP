---
import WaveformCanvas from "./WaveformCanvas.astro";
import CountdownBand from "./CountdownBand.astro";
---

<article class="voice-card-mock" aria-label="voice card preview">
  <header>
    <div class="creator">
      <span class="avatar">A</span>
      <div>
        <p class="creator-name">Airi Nova</p>
        <p class="posted">2時間前に公開</p>
      </div>
    </div>
    <span class="status">LIVE</span>
  </header>

  <h3>「おはよう、今日も一緒にがんばろう」</h3>

  <WaveformCanvas urgent={false} />

  <div class="price-row">
    <div class="price-tag">
      <span class="price-label">ストリーミング</span>
      <span class="price-value">¥120</span>
    </div>
    <div class="price-tag">
      <span class="price-label">ダウンロード</span>
      <span class="price-value">¥250</span>
    </div>
  </div>

  <CountdownBand />
</article>
