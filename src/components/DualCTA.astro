---
interface Props {
  primaryHref: string;
  secondaryHref: string;
  primaryLabel?: string;
  secondaryLabel?: string;
  ariaLabel?: string;
}

const {
  primaryHref,
  secondaryHref,
  primaryLabel = "聴いてみる",
  secondaryLabel = "投稿をはじめる",
  ariaLabel = "primary actions",
} = Astro.props;
---

<div class="dual-cta" role="group" aria-label={ariaLabel}>
  <a class="cta cta-coral" href={primaryHref} target="_blank" rel="noreferrer">{primaryLabel}</a>
  <a class="cta cta-purple" href={secondaryHref} target="_blank" rel="noreferrer">{secondaryLabel}</a>
</div>
