---
import DualCTA from "./DualCTA.astro";
import HeroMotionLayer from "./HeroMotionLayer.astro";
import HeroIllustration from "./HeroIllustration.astro";
import VoiceCardMock from "./VoiceCardMock.astro";
import WaveformCanvas from "./WaveformCanvas.astro";

interface Props {
  lang: "ja" | "en";
  appStoreUrl: string;
}

const { lang, appStoreUrl } = Astro.props;
const isEn = lang === "en";

const t = isEn
  ? {
      eyebrow: "For VTubers & Fans",
      title: "Limited, but joyful.",
      lead:
        "PicoVoice is a VTuber voice marketplace where fans discover and own short voice moments before they disappear.",
      leadSub:
        "Each listing is typically around 30 seconds and sold for a limited time with STREAM or EXPORT purchase options.",
      badges: ["~30 sec voices", "Limited-time drops", "STREAM / EXPORT"],
      ctaPlay: "Start Listening",
      ctaCreate: "Start as Creator",
      ctaAria: "primary actions",
      preview: "Voice Market Preview",
      features: [
        { h: "Made for VTuber fans", p: "Collect voice moments from your favorite creators and keep them close in your daily life." },
        { h: "Timed drops create hype", p: "Every listing has an end time. Scarcity and timing make each release feel special." },
        { h: "Two purchase modes", p: "Choose STREAM for in-app playback or EXPORT for file-based use." },
      ],
      capEyebrow: "Core Capabilities",
      capTitle: "Product experiences for both creators and viewers",
      caps: [
        { h: "Discovery (S04 / S09)", p: "Browse live and ended voices in Marketplace and Library with a unified card UI." },
        { h: "Voice Detail (S05)", p: "Preview, purchase, play, and export from a single detail surface with countdown visibility." },
        { h: "Entitlements", p: "STREAM unlocks in-app playback, and EXPORT unlocks downloadable usage based on your purchase." },
        { h: "Creator Flow (S10-S13)", p: "Creators can record, set metadata, upload, and publish short-form voice content." },
      ],
      showcaseEyebrow: "S04-inspired Card Language",
      showcaseTitle: "The app's visual language, translated to web",
      flowEyebrow: "How It Works",
      flowTitle: "Simple loop for fans and creators",
      flowSteps: [
        "Find a voice in Marketplace",
        "Choose STREAM or EXPORT",
        "Enjoy playback or saved usage before expiration",
        "Creators launch new timed drops",
      ],
      links: [
        { href: "/what-is-picovoice", label: "What is PicoVoice" },
        { href: "/faq", label: "FAQ" },
        { href: "/ai-guide", label: "AI Guide" },
      ],
    }
  : {
      eyebrow: "VTuberと視聴者のために",
      title: "Limited, but joyful.",
      lead:
        "PicoVoiceは、VTuberの声を「今だけ」の体験として届ける、視聴者向けボイスマーケットプレイスです。",
      leadSub:
        "1作品は約30秒。期間限定で販売され、購入方式は STREAM / EXPORT から選べます。",
      badges: ["30秒前後", "期間限定ドロップ", "STREAM / EXPORT"],
      ctaPlay: "聴いてみる",
      ctaCreate: "投稿をはじめる",
      ctaAria: "主な操作",
      preview: "Voice Market Preview",
      features: [
        { h: "VTuber視聴者向け体験", p: "推しの声を短尺で集められる。日常の通知やアラームにも使いやすい設計です。" },
        { h: "期間限定で熱量が高まる", p: "公開期限があるため、リリースの一瞬一瞬に価値が生まれます。" },
        { h: "2つの購入方式", p: "STREAMはアプリ内再生、EXPORTは保存利用。用途別に選べます。" },
      ],
      capEyebrow: "Core Capabilities",
      capTitle: "視聴者とクリエイター双方の主要機能",
      caps: [
        { h: "探索（S04 / S09）", p: "MarketplaceとLibraryで、LIVE/ENDEDを切り替えながらボイスを探せます。" },
        { h: "作品詳細（S05）", p: "試聴・購入・再生・保存を1画面で完結。カウントダウン表示で期限も把握できます。" },
        { h: "購入権限", p: "STREAMは再生権、EXPORTは保存権。購入状態に応じて利用体験が切り替わります。" },
        { h: "投稿フロー（S10-S13）", p: "録音、メタ入力、アップロード進捗を経て、短尺ボイスを公開できます。" },
      ],
      showcaseEyebrow: "S04-inspired Card Language",
      showcaseTitle: "アプリ本体のUIトーンを、そのままWebへ",
      flowEyebrow: "How It Works",
      flowTitle: "聴く人にも、つくる人にも、シンプルな導線",
      flowSteps: [
        "Marketplaceでボイスを見つける",
        "STREAM / EXPORT を選んで購入",
        "期限内に再生・保存して楽しむ",
        "クリエイターが新しい期間限定ドロップを公開",
      ],
      links: [
        { href: "/what-is-picovoice", label: "What is PicoVoice" },
        { href: "/faq", label: "FAQ" },
        { href: "/ai-guide", label: "AI Guide" },
      ],
    };
---

<section class="hero-lp">
  <HeroMotionLayer />
  <div class="hero-grid">
    <div class="hero-copy reveal-up">
      <p class="eyebrow">{t.eyebrow}</p>
      <h1>{t.title}</h1>
      <p class="lead">{t.lead}</p>
      <p class="lead-sub">{t.leadSub}</p>
      <div class="hero-badges" aria-label="core properties">
        {t.badges.map((badge) => <span>{badge}</span>)}
      </div>
      <DualCTA
        primaryHref={appStoreUrl}
        secondaryHref={appStoreUrl}
        primaryLabel={t.ctaPlay}
        secondaryLabel={t.ctaCreate}
        ariaLabel={t.ctaAria}
      />
    </div>

    <div class="hero-visual reveal-up delay-1">
      <div class="hero-visual-shell">
        <HeroIllustration />
        <div class="hero-floating-card">
          <p>{t.preview}</p>
          <WaveformCanvas urgent={true} />
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section-grid reveal-up delay-1">
  {t.features.map((item) => (
    <article class="feature-card">
      <h2>{item.h}</h2>
      <p>{item.p}</p>
    </article>
  ))}
</section>

<section class="capability reveal-up delay-2">
  <div class="showcase-head">
    <p class="eyebrow">{t.capEyebrow}</p>
    <h2>{t.capTitle}</h2>
  </div>
  <div class="capability-grid">
    {t.caps.map((item) => (
      <article class="capability-card">
        <h3>{item.h}</h3>
        <p>{item.p}</p>
      </article>
    ))}
  </div>
</section>

<section class="showcase reveal-up delay-2">
  <div class="showcase-head">
    <p class="eyebrow">{t.showcaseEyebrow}</p>
    <h2>{t.showcaseTitle}</h2>
  </div>
  <VoiceCardMock />
</section>

<section class="flow reveal-up delay-2">
  <div class="flow-copy">
    <p class="eyebrow">{t.flowEyebrow}</p>
    <h2>{t.flowTitle}</h2>
    <ol>
      {t.flowSteps.map((step) => <li>{step}</li>)}
    </ol>
  </div>
  <div class="flow-cta">
    <DualCTA
      primaryHref={appStoreUrl}
      secondaryHref={appStoreUrl}
      primaryLabel={t.ctaPlay}
      secondaryLabel={t.ctaCreate}
      ariaLabel={t.ctaAria}
    />
    <div class="inline-links">
      {t.links.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </div>
  </div>
</section>
