---
interface Props {
  urgent?: boolean;
}

const { urgent = false } = Astro.props;
---

<div class="wave-wrap" data-wave-wrap>
  <canvas class="wave-canvas" width="840" height="88" data-wave-canvas data-urgent={urgent ? "true" : "false"}></canvas>
</div>

<script is:inline>
  (() => {
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const canvases = document.querySelectorAll("[data-wave-canvas]");

    canvases.forEach((canvasEl, index) => {
      const canvas = canvasEl;
      if (canvas.dataset.initialized === "true") return;
      canvas.dataset.initialized = "true";
      const ctx = canvas.getContext("2d");
      if (!ctx) return;

      const urgent = canvas.dataset.urgent === "true";
      let rafId = null;
      let tick = 0;

      const resize = () => {
        const rect = canvas.parentElement.getBoundingClientRect();
        const ratio = window.devicePixelRatio || 1;
        canvas.width = Math.floor(rect.width * ratio);
        canvas.height = Math.floor(88 * ratio);
        canvas.style.height = "88px";
        ctx.setTransform(ratio, 0, 0, ratio, 0, 0);
      };

      const draw = () => {
        const width = canvas.width / (window.devicePixelRatio || 1);
        const height = 88;
        ctx.clearRect(0, 0, width, height);

        const bars = Math.max(24, Math.floor((width - 12) / 12));
        const barW = 6;
        const gap = 6;
        const baseY = height / 2;

        for (let i = 0; i < bars; i += 1) {
          const x = i * (barW + gap);
          const seed = i * 0.45 + tick * (urgent ? 1.8 : 1.1) + index * 0.2;
          const amp = urgent ? 23 : 16;
          const pulse = Math.sin(seed) * 0.5 + Math.sin(seed * 0.35) * 0.5;
          const h = Math.max(8, Math.abs(pulse) * amp + 10);

          const grad = ctx.createLinearGradient(0, baseY - h / 2, 0, baseY + h / 2);
          if (urgent) {
            grad.addColorStop(0, "#FF5E7E");
            grad.addColorStop(1, "#8A78F8");
          } else {
            grad.addColorStop(0, "#8A78F8");
            grad.addColorStop(1, "#6F4CE3");
          }

          ctx.fillStyle = grad;
          ctx.beginPath();
          const r = 3;
          ctx.moveTo(x + r, baseY - h / 2);
          ctx.arcTo(x + barW, baseY - h / 2, x + barW, baseY + h / 2, r);
          ctx.arcTo(x + barW, baseY + h / 2, x, baseY + h / 2, r);
          ctx.arcTo(x, baseY + h / 2, x, baseY - h / 2, r);
          ctx.arcTo(x, baseY - h / 2, x + barW, baseY - h / 2, r);
          ctx.closePath();
          ctx.fill();
        }

        if (!prefersReducedMotion) {
          tick += 0.02;
          rafId = window.requestAnimationFrame(draw);
        }
      };

      resize();
      draw();
      window.addEventListener("resize", resize);

      if (prefersReducedMotion && rafId) {
        cancelAnimationFrame(rafId);
      }
    });
  })();
</script>
