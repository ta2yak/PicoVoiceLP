---
import WaveformCanvas from "./WaveformCanvas.astro";

interface Props {
  previewLabel?: string;
}

const { previewLabel = "Now Playing" } = Astro.props;
---

<div class="hero-card">
  <div class="hero-card-image">
    <img src="/lp.png" alt="PicoVoice — 紫髪猫耳VTuberキャラクター" loading="eager" />
  </div>
  <div class="hero-card-player">
    <div class="hero-card-player-info">
      <img src="/app-icon.png" alt="PicoVoice" class="hero-app-icon" width="36" height="36" />
      <div class="hero-card-player-text">
        <span class="hero-card-player-label">{previewLabel}</span>
        <span class="hero-card-player-app">PicoVoice</span>
      </div>
    </div>
    <div class="hero-card-waveform">
      <WaveformCanvas urgent={true} />
    </div>
  </div>
</div>
