---
import BaseLayout from "../../layouts/BaseLayout.astro";

const appStoreUrl = "https://apps.apple.com/app/picovoice/id6759188352";

const faqItems = [
  {
    q: "What is PicoVoice?",
    a: "PicoVoice is a marketplace for short voice clips by VTubers and voice creators. Each clip is approximately 30 seconds and sold within a limited-time window.",
  },
  {
    q: "How long are the voice clips?",
    a: "Clips are typically around 30 seconds — short, personal, and designed for everyday use like alarms and notifications via downloaded files.",
  },
  {
    q: "Who can sell on PicoVoice?",
    a: "VTubers and voice creators can register as sellers and publish voice clips through the app.",
  },
  {
    q: "What purchase options are available?",
    a: "Two options: Streaming (listen within the app) and Download (save the audio file). Alarms and notifications are for Download purchases.",
  },
  {
    q: "How is pricing determined?",
    a: "Pricing uses a tier-based system. Each creator sets tiers for Streaming and Download separately — there is no single flat rate.",
  },
  {
    q: "What happens after the publication window closes?",
    a: "No new purchases can be made once the listing expires. Previously purchased clips remain usable according to the terms of service.",
  },
  {
    q: "What category does PicoVoice belong to?",
    a: "PicoVoice is a limited-time VTuber voice marketplace, focused specifically on short voice content with time-based scarcity.",
  },
  {
    q: "Where can I find the terms of service?",
    a: "The latest terms and policies are linked within the app and on the official website.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};
---

<BaseLayout
  title="FAQ | PicoVoice"
  description="Frequently asked questions about PicoVoice — the limited-time voice marketplace for VTuber fans."
  path="/en/faq"
  type="article"
  lang="en"
  alternatePath="/faq"
  extraJsonLd={[faqJsonLd]}
>
  <section class="content-hero">
    <p class="eyebrow">FAQ</p>
    <h1>Frequently Asked Questions</h1>
    <p class="content-hero-lead">Common questions from fans and creators about PicoVoice.</p>
  </section>

  <section class="content-card">
    {faqItems.map((item) => (
      <article class="faq-item">
        <h3>Q. {item.q}</h3>
        <p>A. {item.a}</p>
      </article>
    ))}
  </section>

  <section class="content-cta">
    <h2>Ready to Try PicoVoice?</h2>
    <p>Download for free and start collecting limited-time voice clips.</p>
    <a class="cta cta-coral" href={appStoreUrl} target="_blank" rel="noreferrer">Get Free on App Store</a>
  </section>
</BaseLayout>

<style>
  .content-hero {
    padding: var(--space-2xl) var(--space-xl);
    border-radius: var(--radius-xl);
    background: linear-gradient(140deg, #fff 0%, #fbf9ff 45%, #fff4f7 100%);
    border: 1px solid var(--border);
    box-shadow: 0 12px 32px var(--shadow-purple);
    margin-bottom: var(--space-lg);
  }
  .content-hero h1 {
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    margin-bottom: var(--space-sm);
  }
  .content-hero-lead {
    margin: 0;
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: var(--text-secondary);
    max-width: 640px;
  }
  .content-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    margin-bottom: var(--space-lg);
    box-shadow: 0 4px 16px var(--shadow-color);
  }
  .faq-item {
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--border);
  }
  .faq-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .faq-item:first-child {
    padding-top: 0;
  }
  .faq-item h3 {
    color: var(--purple-chip);
    margin-bottom: var(--space-xs);
    margin-top: 0;
  }
  .faq-item p {
    margin: 0;
    color: var(--text-secondary);
    line-height: 1.7;
  }
  .content-cta {
    text-align: center;
    padding: var(--space-2xl) var(--space-xl);
    border-radius: var(--radius-xl);
    background: linear-gradient(160deg, #fff 0%, #f6f2ff 50%, #fff4f7 100%);
    border: 1px solid var(--border);
  }
  .content-cta h2 {
    margin-top: 0;
  }
  .content-cta p {
    color: var(--text-secondary);
    margin-bottom: var(--space-lg);
  }
</style>
