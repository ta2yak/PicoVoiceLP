---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LandingTop from "../../components/LandingTop.astro";
import { resolveAppStoreURL } from "../../lib/app-store-url";

const appStoreUrl = resolveAppStoreURL("en");
---

<BaseLayout
  title="PicoVoice | Own Your Favorite Voice, Before It's Gone"
  description="Collect limited-time VTuber voices. ~30 second drops with Streaming & Download options. Free app for fans."
  path="/en/"
  lang="en"
  alternatePath="/"
>
  <LandingTop lang="en" appStoreUrl={appStoreUrl} />
</BaseLayout>
