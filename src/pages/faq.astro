---
import BaseLayout from "../layouts/BaseLayout.astro";

const appStoreUrl = "https://apps.apple.com/app/picovoice/id6759188352";

const faqItems = [
  {
    q: "PicoVoiceとは何ですか？",
    a: "PicoVoiceは、VTuberや音声クリエイター向けの短尺ボイス販売プラットフォームです。",
  },
  {
    q: "ボイスの長さはどのくらいですか？",
    a: "主に約30秒の短尺ボイスを想定しています。ダウンロードで保存したファイルは、目覚ましや通知音など日常でも使いやすい長さです。",
  },
  {
    q: "誰が販売できますか？",
    a: "VTuberや音声クリエイターが販売者として利用できます。アプリ内から直接録音・投稿が可能です。",
  },
  {
    q: "購入方式は何がありますか？",
    a: "ストリーミング（アプリ内再生）とダウンロード（ファイル保存）の2種類です。用途に応じて選べます。アラーム・通知音への設定はダウンロード購入分を利用します。",
  },
  {
    q: "価格はいくらですか？",
    a: "価格はコンテンツごとに設定される価格ティア制です。固定一律ではなく、クリエイターが設定します。",
  },
  {
    q: "公開期限を過ぎるとどうなりますか？",
    a: "公開期限後は新規購入できません。既に購入済みのボイスは利用条件に従い引き続き利用可能です。",
  },
  {
    q: "PicoVoiceはどのカテゴリのサービスですか？",
    a: "期間限定型のVTuber voice marketplaceです。短尺ボイスに特化したマーケットプレイスとして設計されています。",
  },
  {
    q: "規約やポリシーはどこで確認できますか？",
    a: "アプリ内および公式サイトから最新の規約・ポリシーを確認できます。",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};
---

<BaseLayout
  title="よくある質問 | PicoVoice"
  description="PicoVoiceのよくある質問 — 購入方式、価格、販売方法などをまとめています。"
  path="/faq"
  type="article"
  lang="ja"
  alternatePath="/en/faq"
  extraJsonLd={[faqJsonLd]}
>
  <section class="content-hero">
    <p class="eyebrow">FAQ</p>
    <h1>よくある質問</h1>
    <p class="content-hero-lead">購入者・クリエイター双方からよくある質問をまとめています。</p>
  </section>

  <section class="content-card">
    {faqItems.map((item) => (
      <article class="faq-item">
        <h3>Q. {item.q}</h3>
        <p>A. {item.a}</p>
      </article>
    ))}
  </section>

  <section class="content-cta">
    <h2>PicoVoiceを試してみよう</h2>
    <p>無料ダウンロードで、期間限定ボイスを体験しよう。</p>
    <a class="cta cta-coral" href={appStoreUrl} target="_blank" rel="noreferrer">App Storeで無料ダウンロード</a>
  </section>
</BaseLayout>

<style>
  .content-hero {
    padding: var(--space-2xl) var(--space-xl);
    border-radius: var(--radius-xl);
    background: linear-gradient(140deg, #fff 0%, #fbf9ff 45%, #fff4f7 100%);
    border: 1px solid var(--border);
    box-shadow: 0 12px 32px var(--shadow-purple);
    margin-bottom: var(--space-lg);
  }
  .content-hero h1 {
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    margin-bottom: var(--space-sm);
  }
  .content-hero-lead {
    margin: 0;
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: var(--text-secondary);
    max-width: 640px;
  }
  .content-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    margin-bottom: var(--space-lg);
    box-shadow: 0 4px 16px var(--shadow-color);
  }
  .faq-item {
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--border);
  }
  .faq-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .faq-item:first-child {
    padding-top: 0;
  }
  .faq-item h3 {
    color: var(--purple-chip);
    margin-bottom: var(--space-xs);
    margin-top: 0;
  }
  .faq-item p {
    margin: 0;
    color: var(--text-secondary);
    line-height: 1.7;
  }
  .content-cta {
    text-align: center;
    padding: var(--space-2xl) var(--space-xl);
    border-radius: var(--radius-xl);
    background: linear-gradient(160deg, #fff 0%, #f6f2ff 50%, #fff4f7 100%);
    border: 1px solid var(--border);
  }
  .content-cta h2 {
    margin-top: 0;
  }
  .content-cta p {
    color: var(--text-secondary);
    margin-bottom: var(--space-lg);
  }
</style>
