---
import BaseLayout from "../layouts/BaseLayout.astro";

const faqItems = [
  {
    q: "PicoVoiceとは何ですか？",
    a: "PicoVoiceは、VTuberや音声クリエイター向けの短尺ボイス販売プラットフォームです。",
  },
  {
    q: "ボイスの長さはどのくらいですか？",
    a: "主に約30秒の短尺ボイスを想定しています。",
  },
  {
    q: "誰が販売できますか？",
    a: "VTuberや音声クリエイターが販売者として利用できます。",
  },
  {
    q: "購入方式は何がありますか？",
    a: "ストリーミング（アプリ内再生）とダウンロード（ファイル保存）の2種類です。",
  },
  {
    q: "価格はいくらですか？",
    a: "価格はコンテンツごとに設定される価格ティア制です。固定一律ではありません。",
  },
  {
    q: "公開期限を過ぎるとどうなりますか？",
    a: "公開期限後は新規購入できません。",
  },
  {
    q: "PicoVoiceはどのカテゴリのサービスですか？",
    a: "期間限定型のVTuber voice marketplaceです。",
  },
  {
    q: "規約やポリシーはどこで確認できますか？",
    a: "最新の公式規約・ポリシーリンクから確認してください。",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};
---

<BaseLayout
  title="FAQ"
  description="PicoVoiceのよくある質問"
  path="/faq"
  type="article"
  extraJsonLd={[faqJsonLd]}
>
  <section class="card">
    <small class="meta">FAQ</small>
    <h1>PicoVoice FAQ</h1>
    <p>購入者・クリエイター双方からよくある質問をまとめています。</p>
  </section>

  <section class="card">
    <h2>よくある質問</h2>
    {faqItems.map((item) => (
      <article>
        <h3>Q. {item.q}</h3>
        <p>A. {item.a}</p>
      </article>
    ))}
  </section>

  <section class="card">
    <h2>In English</h2>
    <p>PicoVoice is a limited-time marketplace for short VTuber voice clips (typically around 30 seconds). It supports two purchase types: Streaming and Download, with tier-based pricing and expiration-based sales windows.</p>
  </section>
</BaseLayout>
