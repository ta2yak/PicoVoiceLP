---
import BaseLayout from "../layouts/BaseLayout.astro";
import LandingTop from "../components/LandingTop.astro";

const appStoreUrl = "https://apps.apple.com/app/picovoice/id6759188352";
---

<BaseLayout
  title="PicoVoice | Limited, but joyful"
  description="VTuberと視聴者向けの30秒・期間限定ボイスマーケット。ストリーミング / ダウンロードに対応。"
  path="/"
  lang="ja"
  alternatePath="/en/"
>
