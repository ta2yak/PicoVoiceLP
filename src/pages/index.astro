---
import BaseLayout from "../layouts/BaseLayout.astro";
import LandingTop from "../components/LandingTop.astro";

const appStoreUrl = "https://apps.apple.com/app/picovoice/id6759188352";
---

<BaseLayout
  title="PicoVoice | 推しの声を、今だけの特別に"
  description="VTuberの限定ボイスを集めよう。約30秒の短尺ボイスが期間限定で登場。ストリーミング・ダウンロード対応の無料アプリ。"
  path="/"
  lang="ja"
  alternatePath="/en/"
>
  <LandingTop lang="ja" appStoreUrl={appStoreUrl} />
</BaseLayout>
